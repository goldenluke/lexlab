---
// Importação do CSS Global (Garante o funcionamento do Tailwind)
import '../styles/global.css';

// Importação dos componentes da interface
import Search from '../components/Search.astro';
import AdminTrigger from '../components/AdminTrigger.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const {
    title,
    description = "Plataforma aberta onde a sociedade civil redige, debate e audita propostas legislativas via GitHub.",
    image = "/banner-social-default.png"
} = Astro.props;

// Configuração de URLs para SEO (Substitua Astro.site no astro.config.mjs)
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'http://localhost:4321');
const socialImageURL = new URL(image, Astro.site || 'http://localhost:4321');
---

<!DOCTYPE html>
<html lang="pt-br" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Primário -->
		<title>{title} | LEXLAB</title>
		<meta name="title" content={`${title} | LEXLAB`} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook / WhatsApp -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={`${title} | LEXLAB`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImageURL} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={`${title} | LEXLAB`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={socialImageURL} />

		<!-- Fontes de alta qualidade -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=Lora:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased min-h-screen flex flex-col selection:bg-blue-100 selection:text-blue-900">

		<!-- Cabeçalho de Navegação -->
		<header class="no-print sticky top-0 z-50 w-full bg-white/90 backdrop-blur-md border-b border-slate-200">
			<div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between gap-6">

				<!-- Logo -->
				<div class="flex items-center gap-3 shrink-0">
					<a href="/" class="flex items-center gap-3 group">
						<div class="bg-blue-600 text-white p-2 rounded-xl shadow-lg shadow-blue-200 group-hover:bg-slate-900 transition-all group-hover:scale-105">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
							</svg>
						</div>
						<span class="font-black tracking-tighter text-2xl hidden md:block">
							LEX<span class="text-blue-600">LAB</span>
						</span>
					</a>
				</div>

				<!-- Barra de Busca -->
				<div class="flex-1 max-w-xl hidden sm:block">
					<Search />
				</div>

				<!-- Navegação e Ações -->
				<nav class="flex items-center gap-4 shrink-0">
					<a href="/como-contribuir" class="text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-blue-600 transition-colors">Manual</a>
					<button
                        onclick="window.print()"
                        class="bg-slate-900 text-white px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-lg hover:bg-blue-600 transition-all active:scale-95"
                    >
						Imprimir PDF
					</button>
				</nav>
			</div>
		</header>

		<!-- Área de Conteúdo Dinâmico -->
		<div class="flex-1 w-full">
			<slot />
		</div>

		<!-- Gatilho de Atualização (Deploy via Webhook) -->
		<AdminTrigger />

		<!-- Rodapé Profissional -->
		<footer class="bg-white border-t border-slate-200 mt-auto py-16 px-4">
			<div class="max-w-6xl mx-auto text-center">
				<p class="font-black tracking-tighter text-xl mb-4">LEX<span class="text-blue-600">LAB</span></p>
				<p class="text-slate-500 text-sm max-w-md mx-auto leading-relaxed mb-8 font-serif italic">
					Transformando cidadãos em coautores do Estado através da tecnologia e transparência.
				</p>
				<div class="flex justify-center gap-8 mb-8 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">
					<a href="/" class="hover:text-blue-600 transition-colors">Início</a>
					<a href="/como-contribuir" class="hover:text-blue-600 transition-colors">Como Contribuir</a>
					<a href="https://github.com/goldenluke/pl-neuropsicologia-sus" target="_blank" class="hover:text-blue-600 transition-colors">GitHub</a>
				</div>
				<div class="pt-8 border-t border-slate-100">
					<p class="text-[9px] text-slate-400 uppercase tracking-widest leading-loose">
						Licença MIT © 2024 — LexLab & Comunidade Aberta de Direito Mental <br/>
						O conteúdo das leis é disponibilizado sob licença Creative Commons.
					</p>
				</div>
			</div>
		</footer>

		<style is:global>
			/* Regras de Tipografia para o conteúdo vindo do Markdown */
			.markdown-content {
				@apply font-serif leading-relaxed text-slate-800 text-justify;
			}

			.markdown-content h1 { @apply font-sans font-black text-4xl mb-8 text-slate-900 text-center uppercase tracking-tighter; }
			.markdown-content h2 { @apply font-sans font-bold text-2xl mt-12 mb-4 text-slate-800 border-l-4 border-blue-600 pl-4; }
			.markdown-content h3 { @apply font-sans font-bold text-xl mt-8 mb-3 text-slate-700; }
			.markdown-content p { @apply mb-6 text-lg; }
			.markdown-content b, .markdown-content strong { @apply font-bold text-slate-900; }

			/* Estilo para Citações/Blocos de Referência */
			.markdown-content blockquote {
				@apply border-l-4 border-slate-300 pl-6 italic text-slate-500 my-8;
			}

			/* Otimização Específica para Impressão Legal */
			@media print {
				.no-print { display: none !important; }
				body { background: white !important; padding: 0 !important; }
				.markdown-content { font-size: 12pt; color: black; line-height: 1.5; }
				.bg-white, .bg-slate-50 { background: transparent !important; box-shadow: none !important; border: none !important; }
				footer { @apply border-t border-slate-300 mt-10 !important; }
			}

			/* Estilização da Barra de Rolagem */
			::-webkit-scrollbar { width: 8px; }
			::-webkit-scrollbar-track { background: #f8fafc; }
			::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; border: 2px solid #f8fafc; }
			::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
		</style>
	</body>
</html>
