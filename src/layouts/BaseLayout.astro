---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import Search from '../components/Search.astro';
import AdminTrigger from '../components/AdminTrigger.astro';
import GithubAuth from '../components/GithubAuth.astro';

// i18n
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';
import { tField } from '../utils/tField';

interface Props {
	title: any;
	description?: string;
	image?: string;
}

// 🔥 1. PROPS
const {
	title,
	description = "Plataforma aberta onde a sociedade civil redige, debate e audita propostas legislativas via GitHub.",
	image = "/web-app-manifest-512x512.png"
} = Astro.props;

// 🔥 2. LANG
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 🔥 3. SAFE TITLE
const safeTitle = tField(title, lang) || "LexLab";

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'http://localhost:4321');
---

<!DOCTYPE html>
<html lang={lang} class="h-full scroll-smooth">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<meta name="generator" content={Astro.generator} />

	<title>{safeTitle} | LEXLAB</title>
	<meta name="description" content={description} />
	<link rel="canonical" href={canonicalURL} />

	<!-- 🔥 FONTES MODERNAS (SEM SERIFA) -->
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

	<link href="https://fonts.googleapis.com/css2?
	family=Inter:wght@400;600;700;900&
	family=Space+Grotesk:wght@500;700&
	display=swap" rel="stylesheet">
</head>

<body class="bg-slate-50 text-slate-900 font-sans antialiased min-h-full flex flex-col">

	<!-- HEADER -->
	<header class="no-print sticky top-0 z-50 w-full bg-white/80 backdrop-blur-xl border-b border-slate-200 shadow-sm">
		<div class="max-w-7xl mx-auto px-4 h-16 sm:h-20 flex items-center justify-between gap-4">

			<!-- LOGO -->
			<a href={`/?lang=${lang}`} class="flex items-center gap-3 group">

				<div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl overflow-hidden shadow border bg-white flex items-center justify-center">
					<img src="/favicon.svg" alt="LexLab" class="w-full h-full p-1.5" />
				</div>

				<h1 class="lexlab-title hidden sm:flex">
					<span class="lexlab-main">LEX</span>
					<span class="lexlab-accent">LAB</span>
				</h1>

			</a>

			<!-- SEARCH -->
			<div class="flex-1 max-w-xl hidden md:block">
				<Search />
			</div>

			<!-- NAV -->
			<nav class="flex items-center gap-2 sm:gap-4 md:gap-6">

				<a href={`/transparencia?lang=${lang}`} class="nav-link">
					{t('nav.transparency')}
				</a>

				<a href={`/como-contribuir?lang=${lang}`} class="nav-link hidden lg:block">
					{t('nav.manual')}
				</a>

				<!-- LANGUAGE -->
				<div class="relative group">
					<button class="lang-btn">
						{lang.toUpperCase()}
					</button>

					<div class="lang-dropdown">
						{Object.entries(languages).map(([code, label]) => {
							const currentUrl = new URL(Astro.url.href);
							currentUrl.searchParams.set('lang', code);
							return (
								<a
									href={currentUrl.search}
									class={`lang-item ${lang === code ? 'active' : ''}`}
								>
									{label}
								</a>
							);
						})}
					</div>
				</div>

				<GithubAuth />
			</nav>

		</div>
	</header>

	<main class="flex-grow w-full">
		<slot />
	</main>

	<AdminTrigger />

	<!-- FOOTER -->
	<footer class="bg-white border-t border-slate-200 py-16 px-6 mt-auto">
		<div class="max-w-7xl mx-auto text-center">

			<h2 class="lexlab-title justify-center mb-4">
				<span class="lexlab-main">LEX</span>
				<span class="lexlab-accent">LAB</span>
			</h2>

			<p class="text-slate-500 text-sm max-w-md mx-auto italic mb-10">
				{t('hero.subtitle')}
			</p>

			<div class="footer-links">
				<a href={`/?lang=${lang}`}>{t('nav.home')}</a>
				<a href={`/transparencia?lang=${lang}`}>{t('nav.transparency')}</a>
				<a href="https://github.com/goldenluke/lexlab" target="_blank">GitHub</a>
			</div>

			<p class="footer-copy">
				Licença MIT © 2026 — LexLab & Comunidade <br/>
				{t('footer.rights')}
			</p>
		</div>
	</footer>

	<!-- 🎨 ESTILO GLOBAL -->
	<style is:global>

		.nav-link {
			@apply text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-blue-600 transition;
		}

		.lang-btn {
			@apply px-3 py-2 bg-slate-100 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-blue-600 hover:text-white transition;
		}

		.lang-dropdown {
			@apply absolute right-0 mt-2 w-40 bg-white border border-slate-200 rounded-2xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition p-2;
		}

		.lang-item {
			@apply block px-4 py-2 text-[10px] font-bold rounded-lg hover:bg-slate-50;
		}

		.lang-item.active {
			@apply bg-blue-50 text-blue-600;
		}

		.footer-links {
			@apply flex flex-wrap justify-center gap-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-10;
		}

		.footer-copy {
			@apply text-[9px] text-slate-400 uppercase tracking-widest;
		}

		/* 🔥 LEXLAB BRANDING (SEM SERIFA) */
		.lexlab-title {
			font-family: 'Space Grotesk', sans-serif !important;
			font-weight: 700;
			letter-spacing: -0.04em;
			text-transform: uppercase;
			display: flex;
			align-items: center;
		}

		.lexlab-main {
			color: #0f172a;
		}

		.lexlab-accent {
			color: #2563eb;
			margin-left: 0.25em;
			position: relative;
		}

		.lexlab-accent::after {
			content: "";
			position: absolute;
			left: 0;
			bottom: -2px;
			width: 100%;
			height: 2px;
			background: #2563eb;
			opacity: 0.6;
		}

		/* MARKDOWN */
		.markdown-content, .prose-legal {
			@apply font-serif leading-relaxed text-slate-800 text-justify;
		}

		.markdown-content h1 {
			@apply font-sans font-black text-4xl mb-8 text-slate-900 text-center uppercase;
		}

		.markdown-content h2 {
			@apply font-sans font-bold text-2xl mt-12 mb-4 border-l-4 border-blue-600 pl-4;
		}

		.markdown-content p {
			@apply mb-6 text-lg;
		}

		@media print {
			.no-print { display: none !important; }
			body { background: white !important; }
		}

	</style>

	<!-- persistência idioma -->
	<script is:inline>
		const urlParams = new URLSearchParams(window.location.search);
		const langParam = urlParams.get('lang');
		if (langParam) {
			localStorage.setItem('lexlab_lang', langParam);
		}
	</script>

</body>
</html>
