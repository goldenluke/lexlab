---
// 1. Importação dos Estilos Globais (Tailwind + Tipografia Jurídica)
import '../styles/global.css';

// 2. Importação de Componentes Estruturais
import Search from '../components/Search.astro';
import AdminTrigger from '../components/AdminTrigger.astro';
import GithubAuth from '../components/GithubAuth.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const {
    title,
    description = "Plataforma aberta onde a sociedade civil redige, debate e audita propostas legislativas via GitHub.",
    image = "/banner-social-default.png"
} = Astro.props;

// Lógica de URLs para SEO (Importante para compartilhamento em redes sociais)
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'http://localhost:4321');
const socialImageURL = new URL(image, Astro.site || 'http://localhost:4321');
---

<!DOCTYPE html>
<html lang="pt-br" class="h-full scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Primário -->
		<title>{title} | LEXLAB</title>
		<meta name="title" content={`${title} | LEXLAB`} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook / WhatsApp -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={`${title} | LEXLAB`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImageURL} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={`${title} | LEXLAB`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={socialImageURL} />

		<!-- Google Fonts: Inter (UI) e Lora (Legal) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=Lora:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
	</head>

	<body class="bg-slate-50 text-slate-900 font-sans antialiased min-h-full flex flex-col selection:bg-blue-100 selection:text-blue-900">

		<!-- CABEÇALHO (HEADER) -->
		<header class="no-print sticky top-0 z-50 w-full bg-white/90 backdrop-blur-md border-b border-slate-200">
			<div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between gap-4 md:gap-8">

				<!-- Logo -->
				<div class="flex items-center gap-3 shrink-0">
					<a href="/" class="flex items-center gap-3 group">
						<div class="bg-blue-600 text-white p-2 rounded-xl shadow-lg shadow-blue-200 group-hover:bg-slate-900 transition-all group-hover:scale-105">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
							</svg>
						</div>
						<span class="font-black tracking-tighter text-2xl hidden sm:block uppercase">
							LEX<span class="text-blue-600">LAB</span>
						</span>
					</a>
				</div>

				<!-- Componente de Busca Global -->
				<div class="flex-1 max-w-xl hidden md:block">
					<Search />
				</div>

				<!-- Navegação e Identidade -->
				<nav class="flex items-center gap-3 md:gap-6 shrink-0">
					<a href="/como-contribuir" class="text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-blue-600 transition-colors hidden lg:block">Manual</a>

                    <GithubAuth />

					<button
                        onclick="window.print()"
                        class="bg-slate-900 text-white px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-lg hover:bg-blue-600 transition-all active:scale-95"
                    >
						PDF
					</button>
				</nav>
			</div>
		</header>

		<!-- CONTEÚDO PRINCIPAL -->
		<!-- A classe flex-grow garante que este elemento empurre o footer para baixo -->
		<main class="flex-grow w-full">
			<slot />
		</main>

		<!-- GATILHO DE DEPLOY (Fica fixo no canto inferior direito) -->
		<AdminTrigger />

		<!-- RODAPÉ (FOOTER) -->
		<footer class="bg-white border-t border-slate-200 py-20 px-6 no-print">
			<div class="max-w-7xl mx-auto flex flex-col items-center text-center">
				<p class="font-black tracking-tighter text-2xl mb-4 uppercase">Lex<span class="text-blue-600">Lab</span></p>
				<p class="text-slate-500 text-sm max-w-md leading-relaxed mb-10 font-serif italic">
					Construindo a soberania legislativa por meio da transparência tecnológica e colaboração popular aberta.
				</p>

				<div class="flex flex-wrap justify-center gap-8 md:gap-12 mb-12 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">
					<a href="/" class="hover:text-blue-600 transition-colors">Portal de Projetos</a>
					<a href="/como-contribuir" class="hover:text-blue-600 transition-colors">Como Contribuir</a>
					<a href="https://github.com/goldenluke/lexlab" target="_blank" class="hover:text-blue-600 transition-colors">GitHub Oficial</a>
				</div>

				<div class="w-full pt-8 border-t border-slate-100 flex flex-col items-center">
					<p class="text-[9px] text-slate-400 uppercase tracking-widest leading-loose">
						Licença MIT © 2024 — LexLab & Comunidade <br/>
						Conteúdo das minutas sob licença Creative Commons (CC BY-SA 4.0).
					</p>
				</div>
			</div>
		</footer>

		<!-- ESTILOS GLOBAIS DE TIPOGRAFIA JURÍDICA -->
		<style is:global>
			/* Texto das Leis e Fundamentação */
			.markdown-content, .prose-legal {
				@apply font-serif leading-relaxed text-slate-800 text-justify;
			}

			.markdown-content h1, .prose-legal h1 { @apply font-sans font-black text-4xl mb-8 text-slate-900 text-center uppercase tracking-tighter; }
			.markdown-content h2, .prose-legal h2 { @apply font-sans font-bold text-2xl mt-12 mb-4 text-slate-800 border-l-4 border-blue-600 pl-4; }
			.markdown-content h3, .prose-legal h3 { @apply font-sans font-bold text-xl mt-8 mb-3 text-slate-700; }
			.markdown-content p, .prose-legal p { @apply mb-6 text-lg; }
			.markdown-content b, .markdown-content strong, .prose-legal strong { @apply font-black text-slate-950; }

			.markdown-content blockquote, .prose-legal blockquote {
				@apply border-l-4 border-slate-300 pl-6 italic text-slate-500 my-10 bg-slate-50/50 py-4 pr-4 rounded-r-2xl;
			}

            .markdown-content ul, .prose-legal ul { @apply list-disc ml-6 mb-8 space-y-3; }
            .markdown-content ol, .prose-legal ol { @apply list-decimal ml-6 mb-8 space-y-3; }

			/* Estilos para a Barra de Rolagem Customizada */
			::-webkit-scrollbar { width: 8px; }
			::-webkit-scrollbar-track { background: #f8fafc; }
			::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; border: 2px solid #f8fafc; }
			::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

			/* CONFIGURAÇÃO DE IMPRESSÃO (Papel A4 Oficial) */
			@media print {
				.no-print { display: none !important; }
				body { background: white !important; padding: 0 !important; }
				.markdown-content, .prose-legal { font-size: 12pt; color: black; line-height: 1.5; }
				.bg-white, .bg-slate-50 { background: transparent !important; color: black !important; box-shadow: none !important; border: none !important; }
                header, footer { border: none !important; margin: 0 !important; padding: 0 !important; }
                .markdown-content h2, .prose-legal h2 { border-left: 2px solid black !important; }
			}
		</style>
	</body>
</html>
