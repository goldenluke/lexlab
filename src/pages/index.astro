---
import fs from 'node:fs';
import path from 'node:path';

import BaseLayout from '../layouts/BaseLayout.astro';
import FilterBar from '../components/FilterBar.astro';

// i18n
import { getLangFromUrl } from '../i18n/utils';
import { tField } from '../utils/tField';

const lang = getLangFromUrl(Astro.url);

const REPO_URL = "https://github.com/goldenluke/lexlab";

// =========================
// HELPER GLOBAL (FIX REAL)
// =========================
function tField(field) {
  if (!field) return '';

  if (typeof field === 'object') {
    return field[lang] || field.pt || field.en || '';
  }

  return field;
}

// =========================
// LOAD PROJECTS
// =========================
const lawsDir = path.resolve('./src/leis/src/projetos-leis');

let projects = [];

if (fs.existsSync(lawsDir)) {
  projects = fs.readdirSync(lawsDir)
    .filter(folder => {
      const fullPath = path.join(lawsDir, folder);
      return fs.lstatSync(fullPath).isDirectory();
    })
    .map(folder => {
      try {
        const configPath = path.join(lawsDir, folder, 'config.json');
        if (!fs.existsSync(configPath)) return null;

        const config = JSON.parse(fs.readFileSync(configPath, 'utf-8'));

        return {
          ...config,
          id: folder,
          tituloFormatado: tField(config.titulo)
        };
      } catch {
        return null;
      }
    })
    .filter(Boolean);
}
---

<BaseLayout title="LexLab">

  <!-- HERO -->
  <header class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-blue-900 text-white px-4 py-20 sm:py-28 md:py-32">

    <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_20%_20%,white,transparent)]"></div>

    <div class="relative max-w-4xl mx-auto text-center">

      <h1 class="lexlab-hero">
        <span class="lexlab-main">LEX</span>
        <span class="lexlab-accent">LAB</span>
      </h1>

      <p class="mt-4 sm:mt-6 text-base sm:text-lg md:text-xl text-slate-300 font-serif italic max-w-2xl mx-auto">
        A inteligência coletiva codificando o futuro legislativo.
      </p>

      <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center items-stretch sm:items-center">

        <a href={`${REPO_URL}/issues/new?template=novo-projeto.yml`}
           target="_blank"
           class="w-full sm:w-auto text-center px-6 py-3 bg-blue-600 hover:bg-blue-700 rounded-xl font-bold shadow-lg transition">
          Protocolar Nova Lei
        </a>

        <a href={`${REPO_URL}/issues/new?template=lacuna-normativa.yml`}
           target="_blank"
           class="w-full sm:w-auto text-center px-6 py-3 bg-white/10 hover:bg-white/20 backdrop-blur rounded-xl font-bold border border-white/20 transition">
          Relatar Falha Jurídica
        </a>

      </div>

    </div>
  </header>

  <!-- FILTRO -->
  <section class="max-w-6xl mx-auto px-4 mt-8 sm:mt-12">
    <FilterBar />
  </section>

  <!-- LISTAGEM -->
  <main class="max-w-7xl mx-auto px-4 py-10 sm:py-16">

    <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-10 sm:mb-12">
      <h2 class="text-2xl sm:text-3xl font-black text-slate-900 uppercase italic">
        Acervo Legislativo
      </h2>
      <div class="hidden sm:block flex-1 h-px bg-slate-200"></div>
    </div>

    {projects.length === 0 && (
      <p class="text-center text-slate-400">
        Nenhum projeto encontrado.
      </p>
    )}

    <div class="grid gap-6 sm:gap-8 md:gap-10 grid-cols-1 sm:grid-cols-2 xl:grid-cols-3">

      {projects.map(p => (
        <div class="group bg-white border border-slate-200 rounded-2xl sm:rounded-3xl p-6 sm:p-8 shadow-sm hover:shadow-2xl transition-all flex flex-col h-full">

          <!-- TAGS -->
          <div class="flex flex-wrap gap-2 mb-4 sm:mb-5">

            {p.status && (
              <span class="px-2.5 py-1 text-[9px] sm:text-[10px] font-black uppercase bg-blue-50 text-blue-600 rounded-lg">
                {p.status}
              </span>
            )}

            {p.esfera && (
              <span class="px-2.5 py-1 text-[9px] sm:text-[10px] font-black uppercase bg-slate-900 text-white rounded-lg">
                {p.esfera}
              </span>
            )}

          </div>

          <!-- 🔥 TÍTULO CORRIGIDO -->
          <h2 class="text-lg sm:text-xl font-bold text-slate-900 mb-3 sm:mb-4 leading-snug group-hover:text-blue-600 transition">
            {p.tituloFormatado}
          </h2>

          <!-- AUTOR -->
          <p class="text-xs sm:text-sm text-slate-400 mb-4 sm:mb-6 italic">
            Relatoria: <span class="text-slate-700 font-semibold">{p.autor}</span>
          </p>

          <!-- LOCAL -->
          {p.localizacao?.pais && (
            <div class="mb-4 sm:mb-6 text-[10px] sm:text-xs text-emerald-700 font-bold uppercase">
              📍 {p.localizacao.pais}
            </div>
          )}

          <!-- BOTÃO -->
          <a
            href={`/projeto/${p.id}`}
            class="mt-auto text-center py-3 bg-slate-900 text-white rounded-xl font-bold hover:bg-blue-600 transition text-sm sm:text-base"
          >
            Analisar Minuta
          </a>

        </div>
      ))}

    </div>

  </main>

</BaseLayout>
