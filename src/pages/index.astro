---
import fs from 'node:fs';
import path from 'node:path';

import BaseLayout from '../layouts/BaseLayout.astro';
import FilterBar from '../components/FilterBar.astro';

// =========================
// CONFIG
// =========================
const REPO_URL = "https://github.com/goldenluke/lexlab";

// =========================
// LOAD PROJECTS
// =========================
const lawsDir = path.resolve('./src/leis/src/projetos-leis');

let projects = [];

if (fs.existsSync(lawsDir)) {
  projects = fs.readdirSync(lawsDir)
    .filter(folder => {
      const fullPath = path.join(lawsDir, folder);
      return fs.lstatSync(fullPath).isDirectory();
    })
    .map(folder => {
      try {
        const configPath = path.join(lawsDir, folder, 'config.json');
        if (!fs.existsSync(configPath)) return null;

        const config = JSON.parse(fs.readFileSync(configPath, 'utf-8'));

        return {
          ...config,
          id: folder
        };
      } catch {
        return null;
      }
    })
    .filter(Boolean);
}

// =========================
// HELPERS
// =========================
function getTitulo(titulo) {
  if (typeof titulo === 'object') {
    return titulo.pt || titulo.en;
  }
  return titulo;
}
---

<BaseLayout title="LexLab">

  <!-- HERO -->
  <header class="bg-white border-b border-slate-200 pt-24 pb-36 px-4">
    <div class="max-w-4xl mx-auto text-center">

      <h1 class="text-6xl md:text-8xl font-black tracking-tighter text-slate-900 mb-6 uppercase italic">
        LEX<span class="text-blue-600">LAB</span>
      </h1>

      <p class="text-xl text-slate-500 font-serif italic max-w-2xl mx-auto">
        A inteligência coletiva codificando o futuro legislativo.
      </p>

    </div>
  </header>

  <!-- AÇÕES -->
  <section class="max-w-6xl mx-auto px-4 -mt-16 mb-24 grid grid-cols-1 md:grid-cols-2 gap-8">

    <a href={`${REPO_URL}/issues/new?template=novo-projeto.yml`}
       target="_blank"
       class="p-8 bg-slate-900 text-white rounded-[2.5rem] shadow-xl hover:bg-blue-700 transition">

      <h3 class="text-xl font-bold">Protocolar Nova Lei</h3>
      <p class="text-sm text-slate-400">Abra um rascunho via Git</p>

    </a>

    <a href={`${REPO_URL}/issues/new?template=lacuna-normativa.yml`}
       target="_blank"
       class="p-8 bg-white border border-slate-200 rounded-[2.5rem] shadow-xl hover:border-red-400 transition">

      <h3 class="text-xl font-bold">Relatar Brecha Jurídica</h3>
      <p class="text-sm text-slate-500">Audite falhas ativas</p>

    </a>

  </section>

  <!-- FILTRO -->
  <FilterBar />

  <!-- LISTAGEM -->
  <main class="max-w-7xl mx-auto px-4 py-12">

    <div class="flex items-center justify-between mb-16 px-4">
      <h2 class="text-3xl font-black text-slate-800 uppercase italic tracking-tighter">
        Acervo Legislativo
      </h2>
      <div class="h-px flex-1 bg-slate-200 mx-8 hidden sm:block"></div>
    </div>

    {projects.length === 0 && (
      <p class="text-center text-slate-400">
        Nenhum projeto encontrado.
      </p>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">

      {projects.map(p => (
        <div
          class="bg-white border border-slate-200 p-10 rounded-[3.5rem] shadow-sm hover:shadow-xl transition flex flex-col h-full"
        >

          <!-- TAGS -->
          <div class="mb-6 flex flex-wrap gap-2">

            {p.status && (
              <span class="px-3 py-1 rounded-lg bg-blue-50 text-blue-600 text-[10px] font-black uppercase tracking-widest">
                {p.status}
              </span>
            )}

            {p.esfera && (
              <span class="px-3 py-1 rounded-lg bg-slate-900 text-white text-[10px] font-black uppercase tracking-widest">
                {p.esfera}
              </span>
            )}

            {p.localizacao?.pais && (
              <span class="px-3 py-1 rounded-lg bg-emerald-50 text-emerald-700 text-[10px] font-bold uppercase">
                📍 {p.localizacao.pais}
              </span>
            )}

          </div>

          <!-- TÍTULO -->
          <h2 class="text-2xl font-bold text-slate-900 mb-4 leading-tight">
            {getTitulo(p.titulo)}
          </h2>

          <!-- AUTOR -->
          <p class="text-sm text-slate-400 mb-8 italic">
            Relatoria: <span class="text-slate-600 font-bold">{p.autor}</span>
          </p>

          <!-- BOTÃO -->
          <a
            href={`/projeto/${p.id}`}
            class="mt-auto block text-center py-4 bg-slate-900 text-white rounded-xl font-bold hover:bg-blue-600 transition"
          >
            Analisar Minuta
          </a>

        </div>
      ))}

    </div>

  </main>

</BaseLayout>
