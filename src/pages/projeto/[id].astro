---
// =========================
// IMPORTS
// =========================
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';

import BaseLayout from '../../layouts/BaseLayout.astro';
import EditButton from '../../components/EditButton.astro';
import Contributors from '../../components/Contributors.astro';
import Comments from '../../components/Comments.astro';

import { tField } from '../../utils/tField';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

// =========================
// STATIC PATHS
// =========================
export async function getStaticPaths() {
  const dir = path.resolve('./src/leis/src/projetos-leis');
  if (!fs.existsSync(dir)) return [];

  return fs.readdirSync(dir)
    .filter(f => fs.lstatSync(path.join(dir, f)).isDirectory())
    .map(f => ({ params: { id: f } }));
}

// =========================
// CONFIG
// =========================
const { id } = Astro.params;
const projectPath = path.resolve(`./src/leis/src/projetos-leis/${id}`);

const configPath = path.join(projectPath, 'config.json');
if (!fs.existsSync(configPath)) return Astro.redirect('/404');

const config = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
const titulo = tField(config.titulo, lang);

// =========================
// LOAD SECTIONS
// =========================
function loadSections(subfolder) {
  const dir = path.join(projectPath, subfolder);
  if (!fs.existsSync(dir)) return [];

  return fs.readdirSync(dir)
    .filter(f => f.endsWith('.md'))
    .sort()
    .map(file => {
      const raw = fs.readFileSync(path.join(dir, file), 'utf-8');

      return {
        raw,
        html: marked.parse(raw),
        gitPath: `src/leis/src/projetos-leis/${id}/${subfolder}/${file}`
      };
    });
}

const docs = loadSections('docs');
const artigos = loadSections('artigos');

// =========================
// DIFF WORD
// =========================
function wordDiff(oldStr = '', newStr = '') {
  const oldWords = oldStr.split(/\s+/);

  return newStr.split(/\s+/).map(word => {
    if (!oldWords.includes(word)) {
      return `<mark class="bg-green-200 px-1 rounded">${word}</mark>`;
    }
    return word;
  }).join(' ');
}

// =========================
// IMPACTO
// =========================
function heatLevel(text) {
  if (text.length > 2000) return 'alto';
  if (text.length > 800) return 'médio';
  return 'baixo';
}

function heatColor(level) {
  if (level === 'alto') return 'bg-red-500';
  if (level === 'médio') return 'bg-yellow-400';
  return 'bg-green-500';
}

// =========================
// SEMÂNTICA
// =========================
function semanticType(text = '') {
  const t = text.toLowerCase();

  if (t.includes('assegurado')) return 'expansão de direito';
  if (t.includes('vedado')) return 'restrição normativa';
  if (t.includes('protocolos')) return 'organização administrativa';

  return 'ajuste técnico';
}
---

<BaseLayout title={titulo}>

<main class="max-w-7xl mx-auto px-4 py-12">

  <!-- HEADER -->
  <header class="mb-16">
    <h1 class="text-4xl md:text-5xl font-black mb-6 uppercase italic">
      {titulo}
    </h1>

    <p class="text-slate-500 italic">
      Relatoria: <b class="text-slate-800">{config.autor}</b>
    </p>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

    <!-- MAIN -->
    <div class="lg:col-span-8 space-y-12">

      <!-- ===================== -->
      <!-- 📜 FUNDAMENTAÇÃO -->
      <!-- ===================== -->
      {docs.length > 0 && (
        <section class="bg-white p-10 rounded-3xl shadow border">

          <h2 class="text-xs uppercase tracking-widest text-slate-400 font-black mb-8">
            Exposição de Motivos
          </h2>

          {docs.map(doc => (
            <div class="relative group mb-10">

              <div class="markdown-content prose-legal" set:html={doc.html} />

              <EditButton path={doc.gitPath} repo={config.github_repo} />

            </div>
          ))}

        </section>
      )}

      <!-- ===================== -->
      <!-- ⚖️ ARTIGOS -->
      <!-- ===================== -->
      {artigos.map((art, i) => {
        const prev = artigos[i - 1]?.raw || '';
        const diff = wordDiff(prev, art.raw);
        const heat = heatLevel(art.raw);
        const semantic = semanticType(art.raw);

        return (
          <div class="space-y-6">

            <!-- CARD -->
            <div class="bg-white border rounded-2xl shadow overflow-hidden">

              <div class="flex justify-between px-6 py-4 bg-slate-50 border-b">

                <span class="font-black uppercase text-sm">
                  Artigo {i + 1}
                </span>

                <div class="flex items-center gap-2">
                  <span class={`w-3 h-3 rounded-full ${heatColor(heat)}`}></span>
                  <span class="text-xs uppercase text-slate-400">
                    impacto {heat}
                  </span>
                </div>

              </div>

              <!-- MARKDOWN CORRETO -->
              <div class="p-6 prose-legal" set:html={art.html}></div>

              <EditButton path={art.gitPath} repo={config.github_repo} />

            </div>

            <!-- DIFF -->
            <div class="bg-white border rounded-xl p-4">
              <h4 class="text-xs uppercase font-black text-slate-400 mb-2">
                Diferença
              </h4>
              <div class="text-sm" set:html={diff}></div>
            </div>

            <!-- COMPARAÇÃO -->
            <div class="grid md:grid-cols-2 gap-4">

              <div class="bg-red-50 border rounded-xl p-4">
                <h4 class="text-xs font-bold text-red-600 mb-2">
                  Versão anterior
                </h4>
                <pre class="text-xs whitespace-pre-wrap">{prev}</pre>
              </div>

              <div class="bg-green-50 border rounded-xl p-4">
                <h4 class="text-xs font-bold text-green-600 mb-2">
                  Versão atual
                </h4>
                <pre class="text-xs whitespace-pre-wrap">{art.raw}</pre>
              </div>

            </div>

            <!-- SEMÂNTICA -->
            <div class="bg-white border rounded-xl p-4">
              <p class="text-sm">⚖️ {semantic}</p>
            </div>

          </div>
        );
      })}

      <Comments />

    </div>

    <!-- SIDEBAR -->
    <aside class="lg:col-span-4 space-y-6">

      <div class="sticky top-24 space-y-6">
        <Contributors repo={config.github_repo} />
      </div>

    </aside>

  </div>

</main>

</BaseLayout>
