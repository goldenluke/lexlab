---
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';

// Importações com níveis corrigidos para src/pages/projeto/[id].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import EditButton from '../../components/EditButton.astro';
import Contributors from '../../components/Contributors.astro';
import Comments from '../../components/Comments.astro';

// 1. Definição das rotas dinâmicas baseada nas pastas de 'src/projetos-leis'
export async function getStaticPaths() {
  const lawsDir = path.resolve('./src/projetos-leis');

  if (!fs.existsSync(lawsDir)) {
    console.warn("⚠️ Diretório src/projetos-leis não encontrado.");
    return [];
  }

  const folders = fs.readdirSync(lawsDir).filter(f =>
    fs.lstatSync(path.join(lawsDir, f)).isDirectory()
  );

  return folders.map(folder => ({
    params: { id: folder }
  }));
}

const { id } = Astro.params;
const projectPath = path.resolve(`./src/projetos-leis/${id}`);

// 2. Carregar Metadados do Projeto (config.json)
const configPath = path.join(projectPath, 'config.json');
let config = { titulo: "Projeto não encontrado", autor: "Desconhecido", status: "Erro", tags: [], github_repo: "" };

if (fs.existsSync(configPath)) {
  config = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
}

// 3. Função para processar os Markdowns (Fundamentação e Artigos)
function loadMarkdownSections(subfolder: string) {
  const dir = path.join(projectPath, subfolder);
  if (!fs.existsSync(dir)) return [];

  return fs.readdirSync(dir)
    .filter(file => file.endsWith('.md'))
    .sort()
    .map(file => {
      const rawContent = fs.readFileSync(path.join(dir, file), 'utf-8');
      return {
        html: marked.parse(rawContent),
        // O CAMINHO DEVE COMEÇAR EM 'src/projetos-leis'
        gitPath: `src/projetos-leis/${id}/${subfolder}/${file}`
      };
    });
}

const docs = loadMarkdownSections('docs');
const artigos = loadMarkdownSections('artigos');

// Descrição dinâmica para redes sociais (SEO)
const seoDescription = `Participe da audiência pública digital do projeto: ${config.titulo}. Proposto por ${config.autor} via LexLab.`;
---

<BaseLayout title={config.titulo} description={seoDescription}>
  <main class="max-w-7xl mx-auto px-4 py-12">

    <!-- CABEÇALHO DO PROJETO -->
    <header class="mb-16">
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8">
        <div class="max-w-4xl text-center lg:text-left">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-blue-600 text-white text-[10px] font-black uppercase tracking-widest mb-6 shadow-xl shadow-blue-100">
                <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-300 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
                </span>
                {config.status}
            </div>
            <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-6 leading-tight tracking-tighter uppercase font-sans">
                {config.titulo}
            </h1>
            <p class="text-xl text-slate-500 font-serif italic">
                Relatoria e Proposição: <span class="text-slate-800 font-bold not-italic">{config.autor}</span>
            </p>
        </div>

        <!-- Tags do Projeto -->
        <div class="flex flex-wrap justify-center lg:justify-end gap-2">
            {config.tags && config.tags.map((tag: string) => (
              <span class="px-3 py-1 bg-white border border-slate-200 text-slate-400 rounded-lg text-[10px] font-black uppercase tracking-widest">
                #{tag}
              </span>
            ))}
        </div>
      </div>
      <div class="w-full h-px bg-slate-200 mt-12"></div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

      <!-- COLUNA PRINCIPAL: CONTEÚDO JURÍDICO -->
      <div class="lg:col-span-8 space-y-12">
        <div class="bg-white rounded-[3rem] shadow-2xl shadow-slate-200 border border-slate-100 overflow-hidden">

          <div class="p-8 md:p-16 lg:p-24">

            <!-- PARTE I: FUNDAMENTAÇÃO (Docs) -->
            {docs.length > 0 && (
              <section class="mb-24">
                <div class="flex items-center gap-4 mb-12">
                    <span class="bg-blue-600 text-white font-black px-3 py-1 rounded-lg text-sm">I</span>
                    <h2 class="text-xs font-black text-slate-400 uppercase tracking-[0.4em]">Exposição de Motivos e Fundamentação</h2>
                </div>
                {docs.map(doc => (
                  <div class="relative group mb-16 last:mb-0">
                    <div class="markdown-content prose-legal" set:html={doc.html} />
                    <EditButton path={doc.gitPath} repo={config.github_repo} />
                  </div>
                ))}
              </section>
            )}

            <!-- Divisor entre fundamentação e corpo da lei -->
            <div class="py-12 flex items-center justify-center no-print">
                <div class="h-px w-24 bg-slate-100"></div>
                <div class="px-6 text-slate-300">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                    </svg>
                </div>
                <div class="h-px w-24 bg-slate-100"></div>
            </div>

            <!-- PARTE II: TEXTO NORMATIVO (Artigos) -->
            {artigos.length > 0 && (
              <section>
                <div class="flex items-center gap-4 mb-12">
                    <span class="bg-blue-600 text-white font-black px-3 py-1 rounded-lg text-sm">II</span>
                    <h2 class="text-xs font-black text-slate-400 uppercase tracking-[0.4em]">Texto Normativo Consolidado</h2>
                </div>
                <div class="space-y-10">
                  {artigos.map(art => (
                    <div class="relative group p-8 md:p-12 bg-slate-50 rounded-[2.5rem] border border-transparent hover:border-blue-200 hover:bg-white transition-all shadow-sm hover:shadow-xl">
                      <div class="markdown-content prose-legal" set:html={art.html} />
                      <EditButton path={art.gitPath} repo={config.github_repo} />
                    </div>
                  ))}
                </div>
              </section>
            )}
          </div>

          <!-- Rodapé do Documento -->
          <div class="bg-slate-900 p-12 text-center">
            <p class="text-slate-500 font-black uppercase text-[10px] tracking-[0.3em] mb-3">Fim da Proposição Legislativa</p>
            <p class="text-white/30 text-[10px] italic max-w-xs mx-auto uppercase">
                Este documento é um rascunho dinâmico gerado pela LexLab Engine v1.0.
            </p>
          </div>
        </div>

        <!-- SEÇÃO DE COMENTÁRIOS: Audiência Pública Digital -->
        <Comments />
      </div>

      <!-- COLUNA LATERAL: GOVERNANÇA E AUDITORIA -->
      <aside class="lg:col-span-4 space-y-8">
        <div class="sticky top-28 space-y-8">

          <!-- Card de Auditoria GitHub -->
          <div class="p-8 bg-slate-900 rounded-[2.5rem] text-white shadow-2xl border border-slate-800">
            <h4 class="font-black text-[10px] uppercase tracking-[0.2em] mb-4 text-blue-400">Auditabilidade Digital</h4>
            <p class="text-sm leading-relaxed text-slate-400 mb-6">
                Este projeto é aberto e imutável. Cada alteração feita no texto pode ser rastreada através do histórico de versões oficial.
            </p>
            <a href={config.github_repo} target="_blank" class="flex items-center justify-center gap-2 w-full py-3 bg-white/5 hover:bg-white/10 rounded-xl text-xs font-bold transition-colors border border-white/10">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                Inspecionar Código-Fonte
            </a>
          </div>

          <!-- Módulo Automático de Contribuidores -->
          <Contributors repo={config.github_repo} />

          <!-- Metadados Técnicos -->
          <div class="p-8 bg-white border border-slate-200 rounded-[2.5rem] shadow-sm">
            <h4 class="font-black text-[10px] text-slate-400 uppercase tracking-widest mb-6">Ficha de Identificação</h4>
            <div class="space-y-5 text-sm">
                <div>
                    <label class="block text-[9px] uppercase text-slate-400 font-black mb-1">ID do Projeto</label>
                    <code class="text-blue-600 font-mono font-bold bg-blue-50 px-2 py-1 rounded-md">{config.id}</code>
                </div>
                <div>
                    <label class="block text-[9px] uppercase text-slate-400 font-black mb-1">Pacto Federativo</label>
                    <span class="text-slate-700 font-bold uppercase text-xs flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"></path></svg>
                        Respeitado (LINDB)
                    </span>
                </div>
                <div class="pt-4 border-t border-slate-100 text-[10px] text-slate-400 leading-relaxed uppercase">
                    Este projeto segue o princípio da integralidade da assistência previsto no Art. 196 da CF/88.
                </div>
            </div>
          </div>

          <!-- Botão de Impressão Lateral -->
          <button onclick="window.print()" class="w-full py-5 bg-slate-900 hover:bg-blue-600 text-white rounded-2xl font-black text-xs uppercase tracking-[0.2em] transition-all shadow-xl active:scale-95 flex items-center justify-center gap-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
            Imprimir Documento
          </button>
        </div>
      </aside>

    </div>
  </main>
</BaseLayout>

<style is:global>
    /* Estilos específicos para polir a renderização do Markdown jurídico */
    .prose-legal h1 { @apply text-3xl font-black mb-8 text-slate-900 text-center uppercase tracking-tighter; }
    .prose-legal h2 { @apply text-2xl font-bold mt-12 mb-4 text-slate-800 border-l-4 border-blue-600 pl-4; }
    .prose-legal h3 { @apply text-xl font-bold mt-8 mb-3 text-slate-700; }
    .prose-legal p { @apply text-lg leading-relaxed mb-6 text-slate-800; }
    .prose-legal ul { @apply list-disc ml-6 mb-8 space-y-3 text-slate-700; }
    .prose-legal ol { @apply list-decimal ml-6 mb-8 space-y-3 text-slate-700; }
    .prose-legal li { @apply pl-2; }
    .prose-legal strong { @apply font-bold text-slate-900; }
    .prose-legal blockquote { @apply border-l-4 border-blue-100 pl-6 italic text-slate-500 my-10 bg-blue-50/30 py-4 pr-4 rounded-r-xl; }
</style>
