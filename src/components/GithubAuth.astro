---
// src/components/GithubAuth.astro
---

<div id="github-auth-container" class="flex items-center gap-3">
  <!-- Botão de Login (Visível quando deslogado) -->
  <button
    id="github-login-btn"
    class="flex items-center gap-2 px-4 py-2 bg-slate-900 text-white rounded-xl text-xs font-black uppercase tracking-widest hover:bg-blue-600 transition-all active:scale-95 shadow-lg"
  >
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
    Entrar com GitHub
  </button>

  <!-- Perfil do Usuário (Oculto por padrão) -->
  <div id="user-profile" class="hidden flex items-center gap-3 bg-white border border-slate-200 p-1 pr-4 rounded-full shadow-sm">
    <img id="user-avatar" src="" alt="Avatar" class="w-8 h-8 rounded-full border border-slate-100" />
    <div class="flex flex-col">
      <span id="user-name" class="text-[10px] font-black text-slate-900 leading-none">Usuário</span>
      <button id="github-logout-btn" class="text-[9px] font-bold text-red-500 uppercase tracking-tighter text-left hover:underline">Sair</button>
    </div>
  </div>
</div>

<script>
  const loginBtn = document.getElementById('github-login-btn');
  const logoutBtn = document.getElementById('github-logout-btn');
  const profileDiv = document.getElementById('user-profile');
  const userName = document.getElementById('user-name');
  const userAvatar = document.getElementById('user-avatar');

  // Lógica para verificar se o usuário já está "conectado"
  function checkAuth() {
    const user = JSON.parse(localStorage.getItem('lexlab_user'));
    if (user) {
      loginBtn.classList.add('hidden');
      profileDiv.classList.remove('hidden');
      userName.innerText = user.login;
      userAvatar.src = user.avatar_url;
    } else {
      loginBtn.classList.remove('hidden');
      profileDiv.classList.add('hidden');
    }
  }

  // Simulação de Login (Para um login real sem backend, redirecionamos para o GitHub)
  loginBtn.addEventListener('click', () => {
    // No futuro, aqui você integraria com Firebase Auth ou Supabase
    // Por enquanto, como é uma plataforma via GitHub, vamos levar o usuário para o login oficial
    window.open('https://github.com/login', '_blank');

    // Simulação amigável para a demo (pode ser removida ao integrar OAuth real)
    // localStorage.setItem('lexlab_user', JSON.stringify({ login: 'Cidadão', avatar_url: 'https://github.com/identicons/jason.png' }));
    // checkAuth();
  });

  logoutBtn.addEventListener('click', () => {
    localStorage.removeItem('lexlab_user');
    window.location.reload();
  });

  checkAuth();
</script>
